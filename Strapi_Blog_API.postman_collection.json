              ],
              "query": [
                {
                  "key": "populate",
                  "value": "*"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Tags",
      "item": [
        {
          "name": "Get All Tags",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:1337/api/blog-tags?populate=*",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "1337",
              "path": [
                "api",
                "blog-tags"
              ],
              "query": [
                {
                  "key": "populate",
                  "value": "*"
